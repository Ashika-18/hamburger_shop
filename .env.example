# Stripe ダッシュボード「開発者」→「APIキー」→「標準キー」→ シークレットキー（テストモード）
# このプロジェクトはサーバー側のシークレットキーのみ必要（公開可能キー pk_test は不要）
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# SSL 接続エラー時のみ（ローカル開発用。本番では使わない）
# STRIPE_DEV_INSECURE=true
# 公開可能キー（pk_test_...）は Stripe.js をブラウザで使う場合のみ。現状の実装では不要
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# フロントエンドの URL（127.0.0.1 と localhost は別扱い。Live Server の表示に合わせる）
CLIENT_URL=http://127.0.0.1:5500

PORT=3000
