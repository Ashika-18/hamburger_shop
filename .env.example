# Stripe ダッシュボード「標準キー」→ シークレットキー（sk_test_...）
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# サイトの URL（決済完了後のリダイレクト先）
# ローカル: http://127.0.0.1:5500
# Render:   https://hamburger-shop.onrender.com （末尾スラッシュなし）
CLIENT_URL=http://127.0.0.1:5500

PORT=3000

# ローカル開発で SSL エラーが出る場合のみ（Render では設定しない）
# STRIPE_DEV_INSECURE=true
